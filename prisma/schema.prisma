generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contato {
  id       String   @id @default(cuid())
  nome     String
  email    String
  telefone String
  servico  String
  mensagem String
  lido     Boolean  @default(false)
  criadoEm DateTime @default(now())

  @@map("contatos")
}
